# =============================================================================
# Instagram Reels Auto Uploader — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all required values.
# NEVER commit your .env file to version control.
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
# Port for the internal HTTP server (default: 3000)
PORT=3000
NODE_ENV=production

# API key to secure the internal endpoints (generate a strong random string)
API_KEY=your_strong_random_api_key_here

# The publicly accessible URL of this server (REQUIRED for Instagram API)
# e.g., https://your-domain.com or an ngrok URL
PUBLIC_URL=https://your-public-domain.com

# ─── Google Drive API ─────────────────────────────────────────────────────────
# Obtained from Google Cloud Console → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Refresh token obtained by running: node scripts/get-refresh-token.js
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ─── Multi-Account Configuration ──────────────────────────────────────────────
# Define your Instagram accounts and their corresponding Google Drive folders
# This must be a valid JSON array.
ACCOUNTS_CONFIG='[
  {
    "accountName": "User 1",
    "instagramAccountId": "your_instagram_business_account_id_1",
    "driveFolderId": "your_videos_folder_id_1",
    "driveUploadedFolderId": "your_uploaded_folder_id_1",
    "telegramThreadId": "optional_topic_thread_id_for_user_1",
    # only for new accounts when you have to follow strick rules
    "isNewAccount": true,
    "warmupStartDate": "date_when_account_is_made"
  }
]'

# Long-lived access token from Meta for Developers
# See: docs/ARCHITECTURE.md for integration details
GRAPH_API_TOKEN=your_meta_graph_api_long_lived_token

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string for Prisma (REQUIRED)
DATABASE_URL="postgresql://user:password@localhost:5432/instagram_uploader?schema=public"

# ─── Upload & Reliability Settings ───────────────────────────────────────────
# How often to poll Google Drive for new videos (cron syntax)
POLLING_CRON=*/10 * * * *

# Delay in seconds between sequential uploads to avoid spam flags (default: 120)
UPLOAD_DELAY_SECONDS=120

# Maximum video file size in bytes (default: 1GB)
MAX_FILE_SIZE_BYTES=1073741824

# Maximum video duration in seconds (default: 15 minutes)
MAX_DURATION_SECONDS=900

# ─── Media & Metadata ────────────────────────────────────────────────────────
# Path to the text file containing your default caption
CAPTION_FILE=./caption.txt

# Path to the default cover image (optional)
# COVER_IMAGE=./cover.jpg

# Maximum times to retry a failed upload before marking it as FAILED
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=5000

# Meta API Polling Configuration
STATUS_POLL_INTERVAL_MS=15000
STATUS_POLL_TIMEOUT_MS=1800000

# ─── Account Health & Automation Strategy ────────────────────────────────────
# Enable dynamic account health scoring (auto-cools down accounts taking API hits)
ENABLE_HEALTH_SCORING=true

# Enable adaptive warmup phase for new accounts (limits posts for first 14 days)
ENABLE_ADAPTIVE_WARMUP=true

# Target daily limit for healthy accounts (used to calculate ramp up)
TARGET_DAILY_LIMIT=40

# Hard cap on daily uploads across the entire system (0 = unlimited)
DAILY_UPLOAD_LIMIT=40

# The default duration for a forced cooldown when health reaches 0 (hours)
DEFAULT_COOLDOWN_HOURS=48

# Number of pending jobs in queue before triggering a Telegram warning
LARGE_QUEUE_WARNING_THRESHOLD=10

# Allowable posting window (videos will only be published during this timeframe)
POSTING_WINDOW_START=08:00
POSTING_WINDOW_END=22:00

# ─── Telegram Notifications ──────────────────────────────────────────────────
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Your Telegram chat ID (or group/channel ID)
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
